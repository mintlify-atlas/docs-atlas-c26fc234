  "keyFeatures": [
    "In-memory key-value storage with hash table and separate chaining",
    "Write-ahead logging (AOF) for crash-safe durability",
    "Crash recovery via deterministic AOF replay",
    "Per-key TTL expiration with passive and active sweeping",
    "Binary snapshot persistence (.rdbx format)",
    "AOF rewrite (log compaction) for bounded disk usage",
    "Interactive REPL mode for local use",
    "TCP server mode on port 6379",
    "Docker and Docker Compose deployment support",
    "Protocol-agnostic engine architecture"
  ],
  "publicApiSurface": [
